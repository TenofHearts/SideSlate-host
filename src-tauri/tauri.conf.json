{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tablet2Screen",
  "version": "0.6.0",
  "identifier": "dev.tablet2screen.host",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tablet2Screen",
        "width": 1120,
        "height": 760,
        "minWidth": 920,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../icon.png", "icons/icon.ico"]
  }
}
