{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SideSlate",
  "version": "1.2.1",
  "identifier": "dev.sideslate.host",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SideSlate",
        "width": 1120,
        "height": 760,
        "minWidth": 920,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["../icon.png", "icons/icon.ico"]
  }
}
